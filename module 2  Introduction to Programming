4. Operators in C
THEORY EXERCISE

Types of operators:

Arithmetic: +, -, *, /, %
Relational: ==, !=, >, <, >=, <=
Logical: &&, ||, !
Assignment: =, +=, -=
Increment/Decrement: ++, --
Bitwise: &, |, ^, ~
Conditional: (condition ? true : false)
LAB EXERCISE
#include<stdio.h>

int main() {
    int a, b;

    printf("Enter two numbers: ");
    scanf("%d %d", &a, &b);

    printf("Addition: %d\n", a + b);
    printf("Subtraction: %d\n", a - b);
    printf("Multiplication: %d\n", a * b);
    printf("Division: %d\n", a / b);

    printf("Equal: %d\n", a == b);
    printf("Greater: %d\n", a > b);

    printf("Logical AND: %d\n", (a > 0 && b > 0));

    return 0;
}
5. Control Flow Statements
THEORY EXERCISE

Decision-making statements:

if statement
if-else statement
nested if-else
switch statement

Example:

if(a > b) {
    printf("A is greater");
} else {
    printf("B is greater");
}
LAB EXERCISE
#include<stdio.h>

int main() {
    int num, month;

    printf("Enter a number: ");
    scanf("%d", &num);

    if(num % 2 == 0)
        printf("Even\n");
    else
        printf("Odd\n");

    printf("Enter month number (1-12): ");
    scanf("%d", &month);

    switch(month) {
        case 1: printf("January"); break;
        case 2: printf("February"); break;
        case 3: printf("March"); break;
        default: printf("Invalid month");
    }

    return 0;
}
6. Looping in C
THEORY EXERCISE

Types of loops:

for loop → used when number of iterations is known
while loop → condition checked before execution
do-while loop → runs at least once
LAB EXERCISE
#include<stdio.h>

int main() {

    // for loop
    for(int i = 1; i <= 10; i++) {
        printf("%d ", i);
    }

    printf("\n");

    // while loop
    int i = 1;
    while(i <= 10) {
        printf("%d ", i);
        i++;
    }

    printf("\n");

    // do-while loop
    i = 1;
    do {
        printf("%d ", i);
        i++;
    } while(i <= 10);

    return 0;
}
7. Loop Control Statements
THEORY EXERCISE
break → exits loop
continue → skips current iteration
goto → jumps to label (not recommended)
LAB EXERCISE
#include<stdio.h>

int main() {

    // break example
    for(int i = 1; i <= 10; i++) {
        if(i == 5)
            break;
        printf("%d ", i);
    }

    printf("\n");

    // continue example
    for(int i = 1; i <= 10; i++) {
        if(i == 3)
            continue;
        printf("%d ", i);
    }

    return 0;
}
